# Backend bind address (must match `frontend` Vite dev proxy: vite.config reads HOST from this repo-root env file)
HOST=127.0.0.1:15173

# Where data is persisted
DATA_DIR=./data
# Summarization (optional): set to true / 1 / on to load a local GGUF and fill the `summary` field.
# SUMMARIZE_ENABLED=true
# SUMMARIZE_MODEL: canonical preset id (case-insensitive), same strings the server logs for the model.
#   Qwen3.5 — qwen3.5:0.8b (default) | qwen3.5:2b | qwen3.5:4b | qwen3.5:9b | qwen3.5:27b | qwen3.5:35b | qwen3.5:122b
#   DeepSeek-R1 distill Qwen (Unsloth Q4_K_M) — deepseek-r1:1.5b | deepseek-r1:7b | deepseek-r1:14b | deepseek-r1:32b
#   Gemma 4 IT (Unsloth GGUF) — gemma:e2b | gemma:e4b | gemma4:26b | gemma4:31b
#   LFM2.5-Instruction — lfm2.5:1.2b
# SUMMARIZE_MODEL=qwen3.5:0.8b

# HTTP Basic auth (must match Authorization: Basic ...)
USERNAME=inkly
PASSWORD=inkly

# Max request body size (bytes). Multipart uploads need the full stream; keep this >= your largest file (default 32 MiB if unset).
MAX_BODY_BYTES=33554432

# Browser CORS: comma-separated allowed origins (Vite dev server). Unset defaults to
# http://127.0.0.1:15173,http://localhost:15173. Use * only for local experiments (not production).
# CORS_ORIGINS=http://127.0.0.1:15173,http://localhost:15173
