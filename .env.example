# Backend bind address (must match `frontend` Vite dev proxy: vite.config reads HOST from this repo-root env file)
HOST=127.0.0.1:15173

# Where data is persisted
DATA_DIR=./data
# Summarization (optional): set to true / 1 / on to load Qwen and fill the `summary` field.
# SUMMARIZE_ENABLED=true
# CPU: use `cargo run -p inkly --release`; set RAYON_NUM_THREADS to physical core count.
# Apple: `cargo build -p inkly --release --features accelerate`. x86 + Intel MKL: `--features mkl`.
# Fast CPU try: `summary-bench --max-article-chars 1536 --max-new-tokens 96` (prefill ~4× cheaper vs ~3k chars).

# HTTP Basic auth (must match Authorization: Basic ...)
USERNAME=inkly
PASSWORD=inkly

# Max request body size (bytes)
MAX_BODY_BYTES=1048576

# Browser CORS: comma-separated allowed origins (Vite dev server). Unset defaults to
# http://127.0.0.1:15173,http://localhost:15173. Use * only for local experiments (not production).
# CORS_ORIGINS=http://127.0.0.1:15173,http://localhost:15173
